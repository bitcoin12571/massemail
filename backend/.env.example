# Copy this file to .env and fill in your values
# DO NOT commit .env to git!

DATABASE_URL=sqlite:./email_dashboard.db
BACKEND_PORT=5000
FRONTEND_URL=http://localhost:3000

# Email Provider: 'preview', 'smtp', 'gmail', 'outlook', 'sendgrid'
EMAIL_PROVIDER=smtp

# SMTP (Mailgun, SendGrid, company server, etc.)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=postmaster@sandbox[YOUR_ID].mailgun.org
SMTP_PASS=your_password_here
EMAIL_FROM=noreply@sandbox[YOUR_ID].mailgun.org

# Alternative: SendGrid API
# SENDGRID_API_KEY=your_key_here

# Alternative: Gmail with App Password
# GMAIL_USER=your@gmail.com
# GMAIL_PASS=your_app_password

NODE_ENV=development
LOG_LEVEL=info
