# DATABASE
# Leave DATABASE_URL empty to use the built-in SQLite database.
# DATABASE_URL=postgresql://emailuser:emailpass@localhost:5432/email_dashboard
DB_HOST=localhost
DB_PORT=5432
DB_NAME=email_dashboard
DB_USER=emailuser
DB_PASSWORD=emailpass

# SENDGRID
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# SERVER
NODE_ENV=development
BACKEND_PORT=5000
FRONTEND_PORT=3000
BACKEND_URL=http://localhost:5000

# REDIS
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# RATE LIMITING
EMAIL_RATE_LIMIT=50
EMAIL_RATE_INTERVAL=60000
