# ============================================
# EMAIL DASHBOARD - BACKEND CONFIGURATION
# ============================================

# Database
DATABASE_URL=sqlite:./email_dashboard.db

# Server
BACKEND_PORT=5000
FRONTEND_URL=http://localhost:3000

# ============================================
# EMAIL PROVIDER CONFIGURATION
# ============================================

# Provider options: 'preview', 'smtp', 'gmail', 'outlook', 'sendgrid', 'resend'
EMAIL_PROVIDER=smtp

# Gmail SMTP Configuration (Generic SMTP approach)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info29730@gmail.com
SMTP_PASS=boxg dffi irsk ikju

# Email settings
EMAIL_FROM=info29730@gmail.com
SENDER_NAME=Email Dashboard

# ============================================
# OPTIONAL: SendGrid (alternative to SMTP)
# ============================================
# SENDGRID_API_KEY=your_sendgrid_api_key_here

# ============================================
# OPTIONAL: Gmail (alternative to SMTP)
# ============================================
# For Gmail: use an App Password, not regular password
# Create at: https://myaccount.google.com/apppasswords
# GMAIL_USER=your_email@gmail.com
# GMAIL_PASS=your_app_password

# ============================================
# LOGGING & DEBUG
# ============================================
NODE_ENV=production
LOG_LEVEL=info
JWT_SECRET=your-super-secret-jwt-key-change-this-in-vercel
